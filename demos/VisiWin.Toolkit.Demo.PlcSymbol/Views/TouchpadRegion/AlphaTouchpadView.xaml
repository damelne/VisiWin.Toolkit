<vw:View x:Class="HMI.AlphaTouchpadView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vw="http://inosoft.com/visiwin7"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    mc:Ignorable="d"
    DataContext="{vw:AdapterBinding Type=vw:StandardTouchpadViewAdapter}"
    KeyboardNavigation.ControlTabNavigation="Once" KeyboardNavigation.TabNavigation="Cycle">

	<vw:View.Style>

        <Style TargetType="vw:View">

            <Setter Property="Background" Value="#00000000" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCalledFromWebViewer}" Value="True">
                    <Setter Property="Background" Value="{x:Null}" />
                </DataTrigger>
            </Style.Triggers>

        </Style>

    </vw:View.Style>
	
    <b:Interaction.Triggers>

        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding ViewLoadedCommand}" />
        </b:EventTrigger>

        <b:EventTrigger EventName="Unloaded">
            <b:InvokeCommandAction Command="{Binding ViewUnLoadedCommand}" />
        </b:EventTrigger>

    </b:Interaction.Triggers>
  
    <AdornerDecorator>

        <Grid x:Name="LayoutRoot">

            <Border x:Name="Border" Background="{DynamicResource ApplicationBackgroundBrush}"
                    CornerRadius="{DynamicResource CornerRadius}"  
                    MinHeight="370"
                    MinWidth="500"
                    MaxHeight="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                                                         AncestorType={x:Type Window}},
                                                         Path=ActualHeight}"
                    MaxWidth="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                                                         AncestorType={x:Type Window}},
                                                         Path=ActualWidth}">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsCalledFromWebViewer}" Value="False">
                                <Setter Property="Width" Value="1232"/>
                                <Setter Property="Height" Value="500"/>
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

                <b:Interaction.Behaviors>
                    <vw:ResizeableFrameworkElementBehavior />
                    <vw:MouseDragElementBehavior ConstrainToParentBounds="True" />
                </b:Interaction.Behaviors>

                <Border.Effect>
                    <StaticResource ResourceKey="ShadowDepth3" />
                </Border.Effect>

                <Grid x:Name="Child">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblAlphaPadDescription" HorizontalAlignment="Left" Margin="24,24,24,24"
                               TextWrapping="Wrap" VerticalAlignment="Top"
                               Foreground="{DynamicResource ForegroundDarkBrush}"
                               FontWeight="DemiBold"
                               Grid.Row="1"
                               FontSize="{DynamicResource FontSize_TouchpadHeadline}"
                               Text="{Binding DescriptionLabelText}" Visibility="{Binding IsCalledFromWebViewer, Converter={StaticResource ReversedBoolToVisibilityConverter}}"/>

                    <vw:TextVarIn x:Name="PART_Touchpadmember"
                                  TouchpadMember="True"
                                  Width="Auto"
                                  Height="32" VerticalAlignment="Top" CornerRadius="4" Margin="24,0,24,0"
                                  Grid.Row="2" Visibility="{Binding IsCalledFromWebViewer, Converter={StaticResource ReversedBoolToVisibilityConverter}}">

                        <b:Interaction.Triggers>

                            <b:EventTrigger EventName="WriteValueCompleted">
                                <b:InvokeCommandAction
                                    Command="{Binding ClearTouchpadRegionCommand}" />
                            </b:EventTrigger>

                        </b:Interaction.Triggers>

                    </vw:TextVarIn>

                    <vw:TouchKeyboard x:Name="TouchKeyboard" Content="TouchKeyboard"
                                      Background="{DynamicResource BlueBrush}"
                                      Style="{StaticResource AlphaTouchKeyboardStyle}"
									  CanUseTouchkeyboardPopup="True"
                                      Margin="24,24,24,0"
                                      Grid.Row="3" Width="Auto" Height="Auto" />

                    <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="0,0,24,0"
                                Height="80" VerticalAlignment="Top">

                        <vw:Button x:Name="CancelButton" HorizontalAlignment="Right"
                                   Style="{StaticResource FlatButton}"
                                   LocalizableText="@[ClientSystem].Dialogs.Common.cmdDiscard"
                                   Command="{Binding ClearTouchpadRegionCommand}"
                                   Focusable="False"
                                   Margin="0,20,20,20">
                        </vw:Button>

                        <vw:Button x:Name="TKey_Return"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource ApplyButtonStyle}"
                                   IsDefault="True"
                                   Margin="0,20,0,20"
                                   Focusable="False"
                                   LocalizableText="@[ClientSystem].Dialogs.Common.cmdApply">

                            <b:Interaction.Triggers>

                                <b:EventTrigger EventName="Click">
                                    <b:InvokeCommandAction Command="{Binding WriteInputValueFromTouchpadCommand}" />
                                </b:EventTrigger>

                            </b:Interaction.Triggers>

                        </vw:Button>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </AdornerDecorator>
    
</vw:View>